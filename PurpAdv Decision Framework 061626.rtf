  // \uc0\u9472 \u9472  ENTITY BUTTONS \u9472 \u9472 \
  document.getElementById("entityBtns").addEventListener("click", function(e) \{\
    var btn = e.target.closest(".ctx-btn");\
    if (!btn) return;\
    document.querySelectorAll("#entityBtns .ctx-btn").forEach(function(b) \{ b.classList.remove("active"); \});\
    btn.classList.add("active");\
    state.entity = btn.dataset.val;\
    state.activated = \{\};\
    renderStakeholders();\
  \});\
\
  // \uc0\u9472 \u9472  INDUSTRY BUTTONS \u9472 \u9472 \
  document.getElementById("industryBtns").addEventListener("click", function(e) \{\
    var btn = e.target.closest(".ctx-btn");\
    if (!btn) return;\
    document.querySelectorAll("#industryBtns .ctx-btn").forEach(function(b) \{ b.classList.remove("active"); \});\
    btn.classList.add("active");\
    state.industry = btn.dataset.val;\
    state.activated = \{\};\
    if (state.entity) renderStakeholders();\
  \});\
\
  // \uc0\u9472 \u9472  STAKEHOLDER GRID (event delegation) \u9472 \u9472 \
  document.getElementById("stepZeroPanel").addEventListener("click", function(e) \{\
    // Stakeholder row toggle\
    var shMain = e.target.closest(".sh-main");\
    if (shMain) \{\
      var row = shMain.closest(".sh-row");\
      var id = row.dataset.id;\
      if (row.classList.contains("checked")) \{\
        row.classList.remove("checked", "compelled");\
        delete state.activated[id];\
        row.querySelectorAll(".reason-btn").forEach(function(b) \{ b.classList.remove("active"); \});\
      \} else \{\
        row.classList.add("checked");\
        state.activated[id] = \{ reason: null \};\
      \}\
      updateCounts();\
      return;\
    \}\
\
    // Reason button\
    var reasonBtn = e.target.closest(".reason-btn");\
    if (reasonBtn) \{\
      var row = reasonBtn.closest(".sh-row");\
      var id = row.dataset.id;\
      row.querySelectorAll(".reason-btn").forEach(function(b) \{ b.classList.remove("active"); \});\
      reasonBtn.classList.add("active");\
      if (state.activated[id]) state.activated[id].reason = reasonBtn.dataset.reason;\
      var isCompulsion = state.compulsionTriggers.indexOf(reasonBtn.dataset.reason) > -1;\
      if (isCompulsion) \{ row.classList.add("compelled"); \} else \{ row.classList.remove("compelled"); \}\
      updateCounts();\
    \}\
  \});\
\
  // \uc0\u9472 \u9472  PROCEED BUTTON \u9472 \u9472 \
  document.getElementById("proceedBtn").addEventListener("click", function() \{\
    if (!this.classList.contains("active")) return;\
    var compelled = document.querySelectorAll(".sh-row.compelled").length;\
    document.getElementById("treeSection").classList.add("active");\
    document.getElementById("treeConnector").classList.add("active");\
    if (compelled > 0) \{\
      document.getElementById("signalBar").classList.add("visible");\
      document.getElementById("q1node").classList.add("highlighted");\
    \} else \{\
      document.getElementById("signalBar").classList.remove("visible");\
      document.getElementById("q1node").classList.remove("highlighted");\
    \}\
    setTimeout(function() \{\
      document.getElementById("treeSection").scrollIntoView(\{ behavior: "smooth", block: "start" \});\
    \}, 200);\
  \});\
\
  // \uc0\u9472 \u9472  RENDER \u9472 \u9472 \
  function mergeStakeholders(entityKey, industryKey) \{\
    var base = entityBase[entityKey];\
    var overlay = industryKey && industryOverlay[industryKey] ? industryOverlay[industryKey] : null;\
    if (!overlay) return base;\
    var merged = \{\};\
    var groups = ["internal","commercial","regulatory","reputational"];\
    groups.forEach(function(g) \{\
      var baseItems = base[g] || [];\
      var overlayItems = overlay[g] || [];\
      // Deduplicate by label, overlay items take precedence\
      var seen = \{\};\
      var combined = [];\
      overlayItems.forEach(function(item) \{ seen[item.label] = true; combined.push(item); \});\
      baseItems.forEach(function(item) \{ if (!seen[item.label]) combined.push(item); \});\
      merged[g] = combined;\
    \});\
    return merged;\
  \}\
\
  function renderStakeholders() \{\
    if (!state.entity) return;\
    var data = mergeStakeholders(state.entity, state.industry);\
    var html = "";\
    Object.keys(data).forEach(function(groupKey) \{\
      var items = data[groupKey];\
      var rows = items.map(function(item) \{\
        var btns = item.reasons.map(function(r) \{\
          return '<button class="reason-btn" data-reason="' + r + '">' + reasonLabels[r] + '</button>';\
        \}).join("");\
        return '<div class="sh-row" data-id="' + item.id + '">' +\
          '<div class="sh-main">' +\
            '<div class="sh-checkbox"></div>' +\
            '<span class="sh-label">' + item.label + '</span>' +\
            '<span class="compulsion-flag">Compulsion Signal</span>' +\
          '</div>' +\
          '<div class="sh-reason">' +\
            '<div class="reason-label">Why are they activated?</div>' +\
            '<div class="reason-opts">' + btns + '</div>' +\
          '</div>' +\
        '</div>';\
      \}).join("");\
      html += '<div><div class="sz-group-name">' + groupNames[groupKey] + '</div><div class="sz-checks">' + rows + '</div></div>';\
    \});\
    document.getElementById("stakeholderGrid").innerHTML = html;\
    updateCounts();\
  \}\
\
  function updateCounts() \{\
    var activated = Object.keys(state.activated).length;\
    var compelled = document.querySelectorAll(".sh-row.compelled").length;\
    document.getElementById("activatedCount").textContent = activated;\
    document.getElementById("compelledCount").textContent = compelled;\
    var btn = document.getElementById("proceedBtn");\
    if (activated > 0) \{ btn.classList.add("active"); \} else \{ btn.classList.remove("active"); \}\
    if (typeof updateSummary === "function") updateSummary();\
  \}\
\
  // \uc0\u9472 \u9472  READINESS STATE \u9472 \u9472 \
  var readiness = \{\
    dims: [[false,false],[false,false,false],[false,false,false],[false,false,false]]\
  \};\
\
  function dimComplete(d) \{\
    return readiness.dims[d].every(function(v)\{ return v; \});\
  \}\
\
  function completedDims() \{\
    return readiness.dims.filter(function(_,i)\{ return dimComplete(i); \}).length;\
  \}\
\
  function updateReadiness() \{\
    var total = completedDims();\
    var scoreEl = document.getElementById("readinessScore");\
    var verdictEl = document.getElementById("readinessVerdict");\
    var actionTitle = document.getElementById("readinessActionTitle");\
    var actionSub = document.getElementById("readinessActionSub");\
    var actionNode = document.getElementById("readinessAction");\
\
    scoreEl.textContent = total + " / 4 dimensions complete";\
\
    actionNode.className = "action-node";\
    if (total === 0) \{\
      verdictEl.textContent = "Not yet assessed";\
      verdictEl.style.background = "var(--rule)";\
      verdictEl.style.color = "var(--mid)";\
      actionTitle.textContent = "Complete the readiness assessment above";\
      actionSub.textContent = "Check each criterion that is satisfied to generate your readiness verdict.";\
    \} else if (total === 4) \{\
      verdictEl.textContent = "Go \'97 Execute";\
      verdictEl.style.background = "var(--speak)";\
      verdictEl.style.color = "#fff";\
      actionNode.classList.add("go");\
      actionTitle.textContent = "Execute with precision.";\
      actionSub.textContent = "Internal first. Monitor in real time. Document everything.";\
    \} else if (total >= 2) \{\
      verdictEl.textContent = "Proceed \'97 Managing Risk";\
      verdictEl.style.background = "var(--wait)";\
      verdictEl.style.color = "#fff";\
      actionNode.classList.add("risk");\
      actionTitle.textContent = "Proceed \'97 but name the gaps.";\
      actionSub.textContent = "Identify which dimensions are incomplete and actively manage those risks.";\
    \} else \{\
      verdictEl.textContent = "Hold";\
      verdictEl.style.background = "#9e3a2d";\
      verdictEl.style.color = "#fff";\
      actionNode.classList.add("hold");\
      actionTitle.textContent = "Hold. Address the gap.";\
      actionSub.textContent = "A botched execution creates a second crisis layered on the first.";\
    \}\
\
    // Highlight complete dims\
    document.querySelectorAll(".rg-dim").forEach(function(dim, i) \{\
      if (dimComplete(i)) \{ dim.classList.add("complete"); \} else \{ dim.classList.remove("complete"); \}\
    \});\
\
    updateSummary();\
  \}\
\
  // \uc0\u9472 \u9472  READINESS CLICK \u9472 \u9472 \
  document.getElementById("readinessGrid").addEventListener("click", function(e) \{\
    var item = e.target.closest(".rg-check-item");\
    if (!item) return;\
    var d = parseInt(item.dataset.dim);\
    var idx = parseInt(item.dataset.idx);\
    readiness.dims[d][idx] = !readiness.dims[d][idx];\
    if (readiness.dims[d][idx]) \{ item.classList.add("checked"); \} else \{ item.classList.remove("checked"); \}\
    updateReadiness();\
  \});\
\
  // \uc0\u9472 \u9472  SUMMARY \u9472 \u9472 \
  function updateSummary() \{\
    var el = document.getElementById("summaryContent");\
\
    var entityLabels = \{ public:"Public Company", private:"Private Company", ngo:"NGO / Non-Profit" \};\
    var industryLabels = \{\
      cpg:"CPG / Consumer", tech:"Technology", finance:"Financial Services",\
      defense:"Defense & Aerospace", health:"Healthcare", pharma:"Pharma & Life Sciences",\
      construction:"Construction & Real Estate", oilgas:"Oil & Gas", utility:"Utilities",\
      energy:"Energy (Other)", crypto:"Crypto & Digital Assets", highered:"Higher Education",\
      ag:"Agriculture & Food", other:"Other"\
    \};\
    var dimTitles = ["Factual Readiness","Organizational Alignment","Messenger Readiness","Infrastructure Readiness"];\
\
    var lines = [];\
\
    // Context\
    var entityStr = state.entity ? entityLabels[state.entity] : "Not selected";\
    var industryStr = state.industry ? industryLabels[state.industry] : "Not selected";\
    lines.push('<div style="margin-bottom:14px;"><div style="font-size:9px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-dark);margin-bottom:5px;">Organization Context</div>');\
    lines.push('<div>' + entityStr + (state.industry ? ' &mdash; ' + industryStr : '') + '</div></div>');\
\
    // Stakeholders\
    var activatedRows = document.querySelectorAll(".sh-row.checked");\
    lines.push('<div style="margin-bottom:14px;"><div style="font-size:9px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-dark);margin-bottom:5px;">Activated Stakeholders (' + activatedRows.length + ')</div>');\
    if (activatedRows.length === 0) \{\
      lines.push('<div style="color:var(--light);font-style:italic;">None selected</div>');\
    \} else \{\
      activatedRows.forEach(function(row) \{\
        var label = row.querySelector(".sh-label").textContent;\
        var activeReason = row.querySelector(".reason-btn.active");\
        var reasonText = activeReason ? activeReason.textContent : "Reason not specified";\
        var isCompelled = row.classList.contains("compelled");\
        lines.push('<div style="padding:2px 0;">' +\
          (isCompelled ? '<span style="color:#856404;font-weight:500;">&#9888; </span>' : '&ndash; ') +\
          label + ' <span style="color:var(--light);">(' + reasonText + ')</span>' +\
        '</div>');\
      \});\
    \}\
    lines.push('</div>');\
\
    // Compulsion signals\
    var compelledCount = document.querySelectorAll(".sh-row.compelled").length;\
    lines.push('<div style="margin-bottom:14px;"><div style="font-size:9px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-dark);margin-bottom:5px;">Compulsion Signals</div>');\
    if (compelledCount === 0) \{\
      lines.push('<div>None detected &mdash; speaking is a choice, not an obligation</div>');\
    \} else \{\
      lines.push('<div style="color:#856404;font-weight:500;">' + compelledCount + ' signal' + (compelledCount > 1 ? 's' : '') + ' detected &mdash; Question 1 likely resolves as Yes</div>');\
    \}\
    lines.push('</div>');\
\
    // Readiness\
    var total = completedDims();\
    var readinessStr = total === 4 ? "Go \'97 all four dimensions complete" :\
                       total >= 2 ? "Proceed with caution \'97 " + (4-total) + " dimension" + (4-total > 1 ? "s" : "") + " incomplete" :\
                       total > 0  ? "Hold \'97 significant gaps remain" :\
                                    "Not yet assessed";\
    lines.push('<div style="margin-bottom:6px;"><div style="font-size:9px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-dark);margin-bottom:5px;">Readiness Assessment</div>');\
    lines.push('<div>' + readinessStr + '</div>');\
\
    if (total > 0 && total < 4) \{\
      var gaps = [];\
      readiness.dims.forEach(function(dim, i) \{\
        if (!dimComplete(i)) gaps.push(dimTitles[i]);\
      \});\
      lines.push('<div style="margin-top:4px;color:var(--light);">Gaps: ' + gaps.join(", ") + '</div>');\
    \}\
    lines.push('</div>');\
\
    el.innerHTML = lines.join("");\
  \}\
\
  // \uc0\u9472 \u9472  RESET \u9472 \u9472 \
  document.getElementById("resetBtn").addEventListener("click", function() \{\
    state.entity = null;\
    state.industry = null;\
    state.activated = \{\};\
    readiness.dims = [[false,false],[false,false,false],[false,false,false],[false,false,false]];\
\
    document.querySelectorAll("#entityBtns .ctx-btn, #industryBtns .ctx-btn").forEach(function(b)\{ b.classList.remove("active"); \});\
    document.getElementById("stakeholderGrid").innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:24px;color:var(--light);font-size:13px;font-style:italic;">Select an entity type above to populate your stakeholder universe</div>';\
    document.getElementById("treeSection").classList.remove("active");\
    document.getElementById("treeConnector").classList.remove("active");\
    document.getElementById("signalBar").classList.remove("visible");\
    document.getElementById("q1node").classList.remove("highlighted");\
    document.querySelectorAll(".rg-check-item").forEach(function(i)\{ i.classList.remove("checked"); \});\
    document.querySelectorAll(".rg-dim").forEach(function(d)\{ d.classList.remove("complete"); \});\
    document.getElementById("readinessScore").textContent = "\'97 / 4 dimensions complete";\
    document.getElementById("readinessVerdict").textContent = "Not yet assessed";\
    document.getElementById("readinessVerdict").style.background = "var(--rule)";\
    document.getElementById("readinessVerdict").style.color = "var(--mid)";\
    document.getElementById("readinessAction").className = "action-node";\
    document.getElementById("readinessActionTitle").textContent = "Complete the readiness assessment above";\
    document.getElementById("readinessActionSub").textContent = "Check each criterion that is satisfied to generate your readiness verdict.";\
    document.getElementById("summaryContent").innerHTML = '<span style="color:var(--light);font-style:italic;">Complete the assessment above to generate your summary.</span>';\
    updateCounts();\
    window.scrollTo(\{ top: 0, behavior: "smooth" \});\
  \});\
\
\})();\
</script>\
